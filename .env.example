# Copy this to .env in the current directory, OR (recommended if you run
# `cerebro` as a global command via pipx/pip) to ~/.cerebro/.env — cerebro
# checks the current directory first, then falls back to ~/.cerebro/.env.
# Fill in whichever you use below. Both have free tiers.
# Groq (free, fast):   https://console.groq.com/keys
GROQ_API_KEY=
# Google Gemini (free): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional model overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash
